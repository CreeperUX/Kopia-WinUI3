<Window
    x:Class="KopiaWinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="Auto,*" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid Padding="20,16" ColumnDefinitions="*,Auto" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="2">
                <TextBlock Text="Rclone WinUI3" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Opacity="0.72" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ToggleSwitch Header="CLI" IsOn="{x:Bind ViewModel.IsCliOutputVisible, Mode=TwoWay}" />
                <Button Command="{x:Bind ViewModel.ToggleAdvancedSettingsCommand}" ToolTipService.ToolTip="高级 rclone 设置">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>
                <Button Content="刷新" Command="{x:Bind ViewModel.RefreshCommand}" />
                <Button Content="校验目标" Command="{x:Bind ViewModel.CheckDestinationCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="320,*">
            <ScrollViewer BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <StackPanel Padding="20" Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Rclone 本体" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.RcloneVersion, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.8" />
                        <TextBlock Text="{x:Bind ViewModel.RclonePath, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.62" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="最近任务" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.ActiveTaskName, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.8" />
                        <TextBlock Text="{x:Bind ViewModel.TaskProgressText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.62" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="当前速度" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.TransferSpeedText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1">
                <StackPanel Padding="24" Spacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="文件同步工作台" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="使用 rclone 作为核心执行 copy、sync 和 check。目标可以是本地路径，也可以直接填写 rclone remote，例如 remote:backup/project。" Opacity="0.72" TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="16">
                        <Border Padding="18" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="源" FontSize="20" FontWeight="SemiBold" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox
                                        PlaceholderText="例如 D:\素材 或 remote:source"
                                        Text="{x:Bind ViewModel.SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        Content="浏览..."
                                        Command="{x:Bind ViewModel.PickSourcePathCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1" Width="64" VerticalAlignment="Center">
                            <TextBlock Text="→" FontSize="34" HorizontalAlignment="Center" Opacity="0.72" />
                        </Grid>

                        <Border Grid.Column="2" Padding="18" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="14">
                                <TextBlock Text="目标" FontSize="20" FontWeight="SemiBold" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox
                                        PlaceholderText="例如 Z:\备份 或 remote:backup"
                                        Text="{x:Bind ViewModel.DestinationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button
                                        Grid.Column="1"
                                        Content="浏览..."
                                        Command="{x:Bind ViewModel.PickDestinationPathCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Padding="18" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                            <TextBlock Text="任务设置" FontSize="20" FontWeight="SemiBold" />

                            <Grid Grid.Row="1" ColumnDefinitions="220,Auto,Auto,Auto" ColumnSpacing="18">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="操作" FontWeight="SemiBold" />
                                    <ComboBox SelectedIndex="{x:Bind ViewModel.OperationIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="复制 copy" />
                                        <ComboBoxItem Content="同步 sync" />
                                    </ComboBox>
                                </StackPanel>

                                <ToggleSwitch
                                    Grid.Column="1"
                                    Header="按校验和比较"
                                    IsOn="{x:Bind ViewModel.UseChecksum, Mode=TwoWay}"
                                    VerticalAlignment="Bottom" />
                                <ToggleSwitch
                                    Grid.Column="2"
                                    Header="传输后 check"
                                    IsOn="{x:Bind ViewModel.VerifyAfterTransfer, Mode=TwoWay}"
                                    VerticalAlignment="Bottom" />
                                <ToggleSwitch
                                    Grid.Column="3"
                                    Header="Dry run 预演"
                                    IsOn="{x:Bind ViewModel.DryRun, Mode=TwoWay}"
                                    VerticalAlignment="Bottom" />
                            </Grid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                <Button
                                    Content="开始执行"
                                    Command="{x:Bind ViewModel.StartTransferCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />
                                <Button Content="仅校验" Command="{x:Bind ViewModel.CheckDestinationCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Padding="18" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                            <TextBlock Text="性能参数" FontSize="20" FontWeight="SemiBold" />

                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                <ComboBox
                                    Header="transfers"
                                    SelectedIndex="{x:Bind ViewModel.TransfersIndex, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="1" />
                                    <ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="8" />
                                    <ComboBoxItem Content="16" />
                                    <ComboBoxItem Content="32" />
                                    <ComboBoxItem Content="64" />
                                </ComboBox>
                                <ComboBox
                                    Grid.Column="1"
                                    Header="checkers"
                                    SelectedIndex="{x:Bind ViewModel.CheckersIndex, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="1" />
                                    <ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="8" />
                                    <ComboBoxItem Content="16" />
                                    <ComboBoxItem Content="32" />
                                    <ComboBoxItem Content="64" />
                                    <ComboBoxItem Content="128" />
                                </ComboBox>
                                <ComboBox
                                    Grid.Column="2"
                                    Header="buffer MB"
                                    SelectedIndex="{x:Bind ViewModel.BufferSizeIndex, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="8" />
                                    <ComboBoxItem Content="16" />
                                    <ComboBoxItem Content="32" />
                                    <ComboBoxItem Content="64" />
                                    <ComboBoxItem Content="128" />
                                </ComboBox>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Padding="18" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Visibility="{x:Bind ViewModel.AdvancedSettingsVisibility, Mode=OneWay}">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                            <TextBlock Text="高级 rclone 设置" FontSize="20" FontWeight="SemiBold" />

                            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                                <TextBox
                                    Header="限速"
                                    PlaceholderText="例如 800M"
                                    Text="{x:Bind ViewModel.BandwidthLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox
                                    Grid.Column="1"
                                    Header="额外参数"
                                    PlaceholderText="例如 --fast-list"
                                    Text="{x:Bind ViewModel.ExtraArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Padding="18" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="18">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="任务监控" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind ViewModel.ActiveTaskName, Mode=OneWay}" Opacity="0.72" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="速度" Opacity="0.62" />
                                    <TextBlock Text="{x:Bind ViewModel.TransferSpeedText, Mode=OneWay}" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock Text="耗时" Opacity="0.62" />
                                    <TextBlock Text="{x:Bind ViewModel.ElapsedTimeText, Mode=OneWay}" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="3" Spacing="3">
                                    <TextBlock Text="ETA" Opacity="0.62" />
                                    <TextBlock Text="{x:Bind ViewModel.EtaText, Mode=OneWay}" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="4" Spacing="3">
                                    <TextBlock Text="状态" Opacity="0.62" />
                                    <TextBlock Text="{x:Bind ViewModel.TaskProgressText, Mode=OneWay}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>

                            <ProgressBar
                                Grid.Row="1"
                                Minimum="0"
                                Maximum="100"
                                Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                                IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}" />

                            <TextBox
                                Grid.Row="2"
                                Visibility="{x:Bind ViewModel.CliOutputVisibility, Mode=OneWay}"
                                Text="{x:Bind ViewModel.CommandOutput, Mode=OneWay}"
                                AcceptsReturn="True"
                                IsReadOnly="True"
                                TextWrapping="Wrap"
                                FontFamily="Cascadia Mono"
                                FontSize="13"
                                MinHeight="220"
                                Padding="14" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
